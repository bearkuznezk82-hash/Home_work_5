import json

content = {}
with open('purchase_log.txt') as f:
  for line in   f:
    line = line.strip()
    dict_ = json.loads(line)
    user_id = dict_["user_id"]
    category = dict_["category"]
    content[user_id] = category


with open('visit_log.csv') as f:
  with open('funnel.csv', 'w') as f2:
    for line in f:
      user_id = line.strip().split(',')[0]
      if user_id in content:
          category = content[user_id]
          f2.write(f"{line.strip()},{category}\n")
