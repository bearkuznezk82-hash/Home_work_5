    if command == "book_info":
        book_number = input("Введите номер книги: ")
        if book_info(books, book_number) != []:
            print(
                f"""#Название книги: {book_info(books,  book_number)[0]['title']}
Автор: {book_info(books,  book_number)[0]['author']}"""
            )
        else:
            print("Книга не найдена в базе")
    elif command == "shelf":
        book_title = input("Введите название книги: ")
        if shelf(directories, book_title) != []:
            book_number = shelf(directories, book_title)[0]["number"]
            for i in directories.items():
                if book_number in (i[1]):
                    print(f"Книга хранится на полке: {i[0]}")
        else:
            print("Книга не найдена в базе")
    elif command == "all":
        books_shelf(books, directories)
    elif command == "add_shelf":
        add_shelf()
    elif command == "del_shelf":
        del_shelf()
    elif command == "add_book":
        add_book()
    elif command == "del_book":
        del_book()
